# =============================================================
# MIBSP - Municipal Integrity & Bribe-Free Service Portal
# Environment Configuration Template
# Copy this file to .env and fill in your values
# =============================================================

# ─── Application ────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=replace-with-secrets-token-hex-32-generate-new

# ─── MySQL (VPS Production) ─────────────────────────────────
MYSQL_HOST=localhost
MYSQL_USER=mibsp_user
MYSQL_PASSWORD=replace-with-strong-db-password
MYSQL_DB=mibsp

# ─── PostgreSQL (Render — auto-set by platform) ─────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── File Uploads ───────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# ─── Redis / Celery (Optional - for notifications) ──────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Email Notifications (Optional) ─────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# AI Assistant (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Security Settings ──────────────────────────────────────
SESSION_LIFETIME_HOURS=8
BCRYPT_LOG_ROUNDS=12

# ─── Admin Defaults (Change after first login!) ─────────────
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@1234
DEFAULT_ADMIN_EMAIL=admin@mibsp.gov.in

# Runtime and notification tuning
NOTIFICATION_TO_EMAIL=ops-team@example.com
AI_RATE_MIN_INTERVAL_SECONDS=3
AI_RATE_WINDOW_SECONDS=60
AI_RATE_MAX_REQUESTS_PER_WINDOW=20
SLA_CHECK_INTERVAL_SECONDS=20
ADMIN_EMAIL_2FA_ENABLED=false
ADMIN_OTP_EXPIRY_MINUTES=5
ADMIN_OTP_LENGTH=6
OPENAI_API_KEY=sk-your-real-key
OPENAI_MODEL=gpt-4o-mini
